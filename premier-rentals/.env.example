# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (exposed to browser — must use VITE_ prefix)
# These use the anon/public key only — never put service role key here.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# Set to any truthy value when PayMongo is configured and ready for payments.
VITE_PAYMONGO_READY=true

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND ONLY (Vercel environment variables — never commit real values)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
RESEND_API_KEY=

# Optional: override the base URL used in checkout redirect links.
# Defaults to the request origin if not set.
PUBLIC_SITE_URL=https://yoursite.vercel.app
